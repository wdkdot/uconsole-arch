pkgbase=linux-uconsole-cm4-git
pkgname=("${pkgbase}")
pkgver=r1328974.6fca6f3b870d
pkgrel=1
pkgdesc="Linux kernel for ClockworkPi uConsole with Raspberry Pi CM4"
arch=('aarch64')
url="https://github.com/ak-rex/ClockworkPi-linux"
license=('GPL-2.0-only')
depends=('coreutils' 'kmod' 'mkinitcpio')
makedepends=('git' 'ccache' 'bc' 'bison' 'flex' 'openssl' 'elfutils' 'pahole' 'cpio' 'perl' 'tar' 'xz')
options=('!strip')

# This package installs the same DTB/DTBO paths as linux-uconsole-cm5-git.
# Keep them mutually exclusive unless DTB/DTBO files are split into a separate boot-files package.
conflicts=('linux-uconsole-cm5-git')

source=(
  "kernel::git+https://github.com/ak-rex/ClockworkPi-linux.git"
)
sha256sums=(
  'SKIP'
)

_cross_compile="${KERNEL_CROSS_COMPILE:-aarch64-linux-gnu-}"

pkgver() {
  cd "${srcdir}/kernel"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "${srcdir}/kernel"

  make ARCH=arm64 CROSS_COMPILE="${_cross_compile}" bcm2711_defconfig

  # CM4 compatibility kernel: use 4K memory pages.
  scripts/config --enable ARM64_4K_PAGES
  scripts/config --disable ARM64_16K_PAGES
  scripts/config --disable ARM64_64K_PAGES

  scripts/config --disable LOCALVERSION_AUTO
  scripts/config --set-str LOCALVERSION "-uconsole-cm4"

  make ARCH=arm64 CROSS_COMPILE="${_cross_compile}" olddefconfig
}

build() {
  cd "${srcdir}/kernel"

  make ARCH=arm64 \
       CROSS_COMPILE="${_cross_compile}" \
       -j"$(nproc)" \
       Image.gz modules dtbs
}

package() {
  cd "${srcdir}/kernel"

  install -Dm644 "arch/arm64/boot/Image.gz" \
    "${pkgdir}/boot/vmlinuz-${pkgbase}"

  make ARCH=arm64 \
       CROSS_COMPILE="${_cross_compile}" \
       INSTALL_MOD_PATH="${pkgdir}/usr" \
       modules_install

  install -d "${pkgdir}/boot"
  cp -a arch/arm64/boot/dts/broadcom/*.dtb "${pkgdir}/boot/"

  if [ -d arch/arm64/boot/dts/overlays ]; then
    install -d "${pkgdir}/boot/overlays"
    cp -a arch/arm64/boot/dts/overlays/*.dtbo "${pkgdir}/boot/overlays/"
    [ -f arch/arm64/boot/dts/overlays/README ] && \
      install -Dm644 arch/arm64/boot/dts/overlays/README \
        "${pkgdir}/boot/overlays/README"
  fi

  install -d "${pkgdir}/etc/mkinitcpio.d"
  cat > "${pkgdir}/etc/mkinitcpio.d/${pkgbase}.preset" << EOF
ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/boot/vmlinuz-${pkgbase}"

PRESETS=('default')

default_image="/boot/initramfs-${pkgbase}.img"
EOF
}
