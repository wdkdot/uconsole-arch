pkgname=uconsolectl
pkgver=0.1.0
pkgrel=1
pkgdesc='Lightweight CLI for uConsole CM5 4G and battery controls'
arch=(aarch64)
url='https://github.com/greenbean/uconsole-arch'
license=(MIT)
depends=(
  python
  modemmanager
)
optdepends=(
  'networkmanager: connection status integration'
  'raspberrypi-utils: pinctrl command for GPIO control'
)
backup=('etc/uconsolectl/uconsolectl.conf')
source=(
  'uconsolectl'
  'uconsolectl.conf'
)
b2sums=(
  '263bd24ac84ca419e4e5da09a51f53f41924019e44fb4a43e8bcd94276908b7f2bdd73e0393d7e3fd684b7a41d7d62098621bbd983682317ad094e69104d3c63'
  '99b5d67a23a57d2fa52ec8bbe4cd43b16a1aa16060bceb4cae0a6ed00938c5db72449ba9cf9a847deb721ee72eeefe4a1120560cbf57b7e210084fc42f6f817b'
)

package() {
  install -Dm755 "${srcdir}/uconsolectl" "${pkgdir}/usr/bin/uconsolectl"
  install -Dm644 "${srcdir}/uconsolectl.conf" "${pkgdir}/etc/uconsolectl/uconsolectl.conf"
}
