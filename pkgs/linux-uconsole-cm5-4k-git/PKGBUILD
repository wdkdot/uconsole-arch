pkgbase=linux-uconsole-cm5-4k-git
pkgname=("${pkgbase}")
pkgver=r1328974.6fca6f3b870d
pkgrel=1
pkgdesc="Linux kernel for ClockworkPi uConsole with Raspberry Pi CM5 and 4K memory pages"
arch=('aarch64')
url="https://github.com/ak-rex/ClockworkPi-linux"
license=('GPL-2.0-only')
depends=('coreutils' 'kmod' 'mkinitcpio')
makedepends=('git' 'bc' 'bison' 'flex' 'openssl' 'elfutils' 'pahole' 'cpio' 'perl' 'tar' 'xz')
options=('!strip')

# This package uses the same CM5 boot slot as linux-uconsole-cm5-git so users
# can switch page size by replacing the pacman package without editing config.txt.
provides=('linux-uconsole-cm5-git')
conflicts=('linux-uconsole-cm5-git' 'linux-uconsole-cm4-git')

_bootslot=linux-uconsole-cm5-git

source=(
  "kernel::git+https://github.com/ak-rex/ClockworkPi-linux.git"
)
sha256sums=(
  'SKIP'
)

_cross_compile="${KERNEL_CROSS_COMPILE:-aarch64-linux-gnu-}"

pkgver() {
  cd "${srcdir}/kernel"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "${srcdir}/kernel"
  make ARCH=arm64 CROSS_COMPILE="${_cross_compile}" bcm2712_defconfig

  # CM5 compatibility kernel: use 4K memory pages.
  scripts/config --enable ARM64_4K_PAGES
  scripts/config --disable ARM64_16K_PAGES
  scripts/config --disable ARM64_64K_PAGES

  scripts/config --disable LOCALVERSION_AUTO
  scripts/config --set-str LOCALVERSION "-uconsole-cm5-4k"
  make ARCH=arm64 CROSS_COMPILE="${_cross_compile}" olddefconfig
}

build() {
  cd "${srcdir}/kernel"

  make ARCH=arm64 \
       CROSS_COMPILE="${_cross_compile}" \
       -j"$(nproc)" \
       Image.gz modules dtbs
}

package() {
  cd "${srcdir}/kernel"

  local kernelrelease
  kernelrelease="$(make ARCH=arm64 CROSS_COMPILE="${_cross_compile}" kernelrelease)"

  install -Dm644 "arch/arm64/boot/Image.gz" \
    "${pkgdir}/boot/vmlinuz-${_bootslot}"

  make ARCH=arm64 \
       CROSS_COMPILE="${_cross_compile}" \
       INSTALL_MOD_PATH="${pkgdir}/usr" \
       modules_install

  install -Dm644 "arch/arm64/boot/Image.gz" \
    "${pkgdir}/usr/lib/modules/${kernelrelease}/vmlinuz"
  echo "${_bootslot}" > "${pkgdir}/usr/lib/modules/${kernelrelease}/pkgbase"

  install -d "${pkgdir}/boot"
  cp -a arch/arm64/boot/dts/broadcom/*.dtb "${pkgdir}/boot/"

  if [ -d arch/arm64/boot/dts/overlays ]; then
    install -d "${pkgdir}/boot/overlays"
    cp -a arch/arm64/boot/dts/overlays/*.dtbo "${pkgdir}/boot/overlays/"
    [ -f arch/arm64/boot/dts/overlays/README ] && \
      install -Dm644 arch/arm64/boot/dts/overlays/README \
        "${pkgdir}/boot/overlays/README"
  fi

  install -d "${pkgdir}/etc/mkinitcpio.d"
  cat > "${pkgdir}/etc/mkinitcpio.d/${_bootslot}.preset" << EOF
ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/boot/vmlinuz-${_bootslot}"

PRESETS=('default')

default_image="/boot/initramfs-${_bootslot}.img"
EOF
}
